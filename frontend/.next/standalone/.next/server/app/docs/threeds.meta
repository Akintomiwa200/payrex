{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/threeds/layout,_N_T_/docs/threeds/page,_N_T_/docs/threeds"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/threeds/__PAGE__",
    "/docs/threeds",
    "/docs",
    "/_index",
    "/_head"
  ]
}