{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/splits/layout,_N_T_/docs/splits/page,_N_T_/docs/splits"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/splits/__PAGE__",
    "/docs/splits",
    "/docs",
    "/_index",
    "/_head"
  ]
}