{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/compliance/layout,_N_T_/docs/compliance/page,_N_T_/docs/compliance"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/compliance/__PAGE__",
    "/docs/compliance",
    "/docs",
    "/_index",
    "/_head"
  ]
}