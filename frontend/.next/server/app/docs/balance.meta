{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/balance/layout,_N_T_/docs/balance/page,_N_T_/docs/balance"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/balance/__PAGE__",
    "/docs/balance",
    "/docs",
    "/_index",
    "/_head"
  ]
}