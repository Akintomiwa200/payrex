{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/kyc/layout,_N_T_/docs/kyc/page,_N_T_/docs/kyc"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/kyc/__PAGE__",
    "/docs/kyc",
    "/docs",
    "/_index",
    "/_head"
  ]
}