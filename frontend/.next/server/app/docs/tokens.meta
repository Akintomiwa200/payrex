{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/tokens/layout,_N_T_/docs/tokens/page,_N_T_/docs/tokens"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/tokens/__PAGE__",
    "/docs/tokens",
    "/docs",
    "/_index",
    "/_head"
  ]
}