{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/disputes/layout,_N_T_/docs/disputes/page,_N_T_/docs/disputes"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/disputes/__PAGE__",
    "/docs/disputes",
    "/docs",
    "/_index",
    "/_head"
  ]
}