{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/subscriptions/layout,_N_T_/docs/subscriptions/page,_N_T_/docs/subscriptions"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/subscriptions/__PAGE__",
    "/docs/subscriptions",
    "/docs",
    "/_index",
    "/_head"
  ]
}